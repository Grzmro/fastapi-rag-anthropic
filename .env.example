# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5
MAX_TOKENS=1024

# Embeddings (local, no API key needed)
# For Polish/multilingual documents consider: intfloat/multilingual-e5-small
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunking & retrieval
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=4

# Chroma persistence
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=documents

# Google Drive ingestion (optional)
# Path to a service-account key JSON. Share your Drive folder with the
# service account's e-mail address (Viewer role) to grant read access.
GOOGLE_SERVICE_ACCOUNT_FILE=./gcp-service-account.json
